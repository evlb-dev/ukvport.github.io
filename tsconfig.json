{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",

    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "jsxImportSource": "react",

    "allowImportingTsExtensions": true,
    "noEmit": true,

    "types": ["astro/client"],

    "esModuleInterop": true,

    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": ["src/**/*", "astro.config.ts"]
}